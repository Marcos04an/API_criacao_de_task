{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "noEmitOnError": true,
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": ["dist", "node_modules"]
}
