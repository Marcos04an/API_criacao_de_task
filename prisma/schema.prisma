generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DATABASE_URL")
}

model User {
  id    String @id @default(uuid())
  email String @unique
  name  String
  age   String

  tasks Task[]
}

model Task {
  id          String  @id @default(uuid())
  title       String  @unique
  description String?
  completed   Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
}
